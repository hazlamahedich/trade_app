# Trade Advisor Configuration
# Copy this file to .env and fill in your values.
# Secrets (API keys) should be stored via: ta config set-key <KEY_NAME>

# ── Data (env_prefix: none, nested under AppConfig.data) ──
# DATA__CACHE_DIR=./data_cache
# DATA__STALENESS_THRESHOLD_SEC=3600
# DATA__RETRY_ATTEMPTS=3
# DATA__RETRY_DELAY_SEC=1.0

# ── Backtest (env_prefix: none, nested under AppConfig.backtest) ──
# BACKTEST__INITIAL_CASH=100000
# BACKTEST__FREQ=1D
# BACKTEST__COST__COMMISSION_PCT=0.0
# BACKTEST__COST__SLIPPAGE_PCT=0.0005

# ── Risk (env_prefix: none, nested under AppConfig.risk) ──
# RISK__MAX_POSITION_SIZE=50000
# RISK__MAX_PORTFOLIO_DRAWDOWN_PCT=20.0
# RISK__MAX_SECTOR_EXPOSURE=30.0
# RISK__DAILY_LOSS_LIMIT=5000

# ── Execution (env_prefix: none, nested under AppConfig.execution) ──
# EXECUTION__SLIPPAGE_MODEL=percentage
# EXECUTION__SLIPPAGE_BPS=5.0
# EXECUTION__COMMISSION_PER_SHARE=0.005
# EXECUTION__COMMISSION_MIN=1.0

# ── Determinism (env_prefix: none, nested under AppConfig.determinism) ──
# DETERMINISM__RANDOM_SEED=42
# DETERMINISM__DETERMINISTIC_MODE=true

# ── Database (env_prefix: none, nested under AppConfig.database) ──
# DATABASE__PATH=./trade_advisor.db
# DATABASE__WAL_MODE=true
# DATABASE__BACKUP_PATH=

# ── Logging (env_prefix: none, nested under AppConfig.logging) ──
# LOGGING__LEVEL=INFO
# LOGGING__JSON_LOGS=false
# LOGGING__AUDIT_LOG_PATH=

# ── Secrets (stored via keyring, NOT in .env) ──
# Use: ta config set-key YAHOO_API_KEY
# Use: ta config set-key ALPHA_VANTAGE_API_KEY
# Use: ta config set-key POLYGON_API_KEY
# Use: ta config set-key TWELVEDATA_API_KEY
# Fallback (not recommended):
# YAHOO_API_KEY=
# ALPHA_VANTAGE_API_KEY=
# POLYGON_API_KEY=
# TWELVEDATA_API_KEY=your_api_key_here
