{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "preact": ["./node_modules/preact"]
    }
  },
  "include": ["events.ts", "islands/**/*.ts"],
  "exclude": ["node_modules"]
}
